# Minimal local reward-service configuration.
KERNELGYM_DEPLOYMENT_PROFILE=external
KERNELGYM_SSH_RUNTIME=physical_host
KERNELGYM_CONTAINER_REQUIRED=true
KERNELGYM_LOCK_GPU_CLOCKS=true

API_HOST=0.0.0.0
API_PORT=10907
API_WORKERS=4
API_RELOAD=false

GPU_DEVICES=[0]
GPU_MEMORY_LIMIT=16GB
NODE_ID=local

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_KEY_PREFIX=kernelgym

WORKER_POOL_SIZE=1
MAX_TASKS_PER_WORKER=1

DEFAULT_TOOLKIT=kernelbench
DEFAULT_BACKEND_ADAPTER=kernelbench
DEFAULT_BACKEND=triton

LOG_LEVEL=INFO
LOG_DIR=logs
ENABLE_METRICS=true
METRICS_PORT=8001
ENABLE_PROFILING=true
VERBOSE_ERROR_TRACEBACK=true

SAVE_EVAL_RESULTS=false
EVAL_RESULTS_PATH=logs/eval_results.jsonl

# CUDA-Agent runtime/cache controls inherited from KernelGYM-vllm018-cuda-agent.
CUDA_HOME=/usr/local/cuda-12.9
KERNELGYM_CUDA_AGENT_NVCC_THREADS=4
KERNELGYM_TVM_FFI_NVCC_THREADS=4
KERNELGYM_CUDA_AGENT_TMPDIR=/dev/shm/kernelgym/work/cuda_agent
KERNELGYM_TVM_FFI_TMPDIR=/dev/shm/kernelgym/work/tvm_ffi
KERNELGYM_CUDA_AGENT_COMPILE_CACHE_DIR=/dev/shm/kernelgym/compile_cache/cuda_agent
KERNELGYM_TVM_FFI_COMPILE_CACHE_DIR=/dev/shm/kernelgym/compile_cache/tvm_ffi
